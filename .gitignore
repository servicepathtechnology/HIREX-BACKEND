# ── Secrets — NEVER commit ───────────────────────────────────────────────────
.env
.env.*
!.env.example
firebase-credentials.json
*.pem
*.key
*.p12

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
wheels/
pip-wheel-metadata/

