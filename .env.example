# HireX Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env or firebase-credentials.json to git.

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/neondb?ssl=require

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase — use ONE of the two options below:
# Option A: File path (local dev)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
# Option B: JSON string (cloud deployment — Render/Railway)
FIREBASE_CREDENTIALS_JSON=

# App
APP_ENV=development
SECRET_KEY=generate-a-strong-random-key
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_CLOUDFRONT_URL=https://your-cloudfront-url.cloudfront.net

# Razorpay (use test keys in development)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Part 4 — AI / Celery
# Use gpt-4o-mini during development to save cost, switch to gpt-4o for production
OPENAI_API_KEY=sk-your-openai-api-key-here
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Part 5 — Growth & Scale
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
MIXPANEL_TOKEN=your-mixpanel-project-token
BRANCH_KEY=key_live_your-branch-key

# Part 1 — 1v1 Live Challenges
# Judge0 API key (RapidAPI) — for coding challenge evaluation
# Get yours at: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_KEY=your-judge0-rapidapi-key
